{
    "name": "oficina/estoque-orcamentos",
    "description": "Sistema de estoque e orçamentos para oficina mecânica",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php bin/migrate.php",
        "serve": "php -S localhost:8080 -t public public/router.php"
    },
    "config": {
        "optimize-autoloader": true
    }
}
